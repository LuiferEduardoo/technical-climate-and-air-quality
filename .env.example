PORT=3000

# https://openaq.org  (free, API key optional but recommended)
OPENAQ_API_KEY=your_key_here

# https://ipinfo.io  (used to detect city from IP when ?city= is omitted)
IPINFO_TOKEN=your_token_here

# https://platform.openai.com/account/api-keys  (used for AI analysis of weather + air quality)
OPENIA_API_KEY=your_key_here
